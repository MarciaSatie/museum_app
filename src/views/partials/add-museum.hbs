
  <form action="/dashboard/addmuseum" method="POST">
    <!-- Museum Name -->
    <div class="field">
      <label class="label">Museum Title</label>
      <input class="input" type="text" placeholder="Enter museum title" name="title" required>
    </div>

    <!-- Museum Description-->
    <div class="field">
      <label class="label">Description</label>
      <textarea class="textarea" placeholder="Enter museum description" name="description" rows="3"></textarea>
    </div>

    <!-- Select a Category -->
    <div class="field">
      <label class="label">Category</label>
      <div class="control">
        <div class="select">
          <select name="categoryId">
            <option value="">-- Select a Category --</option>
            {{#each categories}}
              <option value="{{this._id}}">{{this.name}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>

    <!-- Latitude and Longitude -->
    <div class="columns">
      <div class="column">
        <div class="field">
          <label class="label">Latitude</label>
          <input class="input" type="number" placeholder="e.g., 53.2743" name="latitude" step="any">
        </div>
      </div>
      <div class="column">
        <div class="field">
          <label class="label">Longitude</label>
          <input class="input" type="number" placeholder="e.g., -9.1193" name="longitude" step="any">
        </div>
      </div>
    </div>

    <!-- Status: Public or Private POI -->
    <div class="field">
      <label class="label">Status</label>
      <div class="control">
        <div class="select">
          <select name="status">
            <option value="">-- Select a Status --</option>
              <option value="private">Private</option>
              <option value="public"selected>Public</option>
          </select>
        </div>
      </div>
    </div>


    <!-- Submit Button -->
    <button class="button is-link">Add Museum</button>
  </form>
