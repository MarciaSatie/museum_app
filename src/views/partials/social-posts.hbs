<form action="/leave-comment" method="POST">
  <div class="field has-addons">
    <div class="control is-expanded">
      <input class="input" name="userText" type="text" placeholder="Type here..." required>
    </div>
    <div class="control">
      <button class="button is-link" type="submit" aria-label="Send comment" title="Send comment">
        <span class="icon"><i class="fas fa-paper-plane" aria-hidden="true"></i></span>
      </button>
    </div>
  </div>
  <input type="hidden" name="galleryOwnerId" value="{{galleryOwnerId}}">
</form>

<div role="region" aria-label="User comments" class="social-comments-vertical" style="max-height:350px; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:0.5rem;">
  {{#each allComments}}
    <div class="box" style="margin-bottom:0.5rem; min-width:0;">
        <p class="is-size-7 has-text-grey">{{displayDate}}</p>
      <p><strong>{{firstName}} {{lastName}}</strong>: {{comment}}</p>
    <div class="field is-grouped">
      <!-- Like Button -->
      <p class="control">
        <a href="/social/like/{{_id}}" class="button is-light is-success" title="Like">
          <span class="icon">
            <i class="fas fa-thumbs-up"></i>
          </span>
          <span>{{like}}</span>
        </a>
      </p>

      <!-- Dislike Button -->
      <p class="control">
        <a href="/social/dislike/{{_id}}" class="button is-light is-danger" title="Dislike">
          <span class="icon">
            <i class="fas fa-thumbs-down"></i>
          </span>
          <span>{{dislike}}</span>
        </a>
      </p>
    </div>

    </div>
  {{/each}}
</div>