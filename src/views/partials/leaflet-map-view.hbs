{{!-- 
Leaflet is a JavaScript library that draws maps in the browser, 
using HTML and the DOM, as  controller runs on the server (Node.js), not in the browser.

I had to add this Javascript code in teh client-side.
--}}


<div id="map-all-museums" style="height: 400px;"></div>
<script>
  const museums = [
    {{#each museums}}
      {
        lat: {{latitude}},
        lng: {{longitude}},
        name: "{{title}}",
        pov: "{{pov}}",
        ownerId: "{{userid}}",
        ownerFirstName: "{{ownerFirstName}}",
        ownerLastName: "{{ownerLastName}}"
      },
    {{/each}}
  ];

  const markerPalette = [
    "#ef4444",
    "#f97316",
    "#eab308",
    "#22c55e",
    "#06b6d4",
    "#3b82f6",
    "#8b5cf6",
    "#ec4899"
  ];

  function colorForOwner(ownerId) {
    const text = ownerId || "anonymous";
    let hash = 0;
    for (let index = 0; index < text.length; index += 1) {
      hash = text.charCodeAt(index) + ((hash << 5) - hash);
    }
    return markerPalette[Math.abs(hash) % markerPalette.length];
  }

  function createColoredMarker(color) {
    return L.divIcon({
      className: "museum-owner-marker",
      html: `<i class="fas fa-map-marker" style="color:${color}; font-size:24px; text-shadow: -1px -1px 2px rgba(0,0,0,0.3), 1px -1px 2px rgba(0,0,0,0.3), -1px 1px 2px rgba(0,0,0,0.3), 1px 1px 2px rgba(0,0,0,0.3);"></i>`,
      iconSize: [24, 24],
      iconAnchor: [12, 24],
      popupAnchor: [0, -18],
    });
  }

  if (museums.length > 0) {
    const map = L.map('map-all-museums').setView([museums[0].lat, museums[0].lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    museums.forEach((museum) => {
      const markerColor = colorForOwner(museum.ownerId);
      const ownerName = `${museum.ownerFirstName} ${museum.ownerLastName}`.trim();
      L.marker([museum.lat, museum.lng], { icon: createColoredMarker(markerColor) })
        .addTo(map)
        .bindPopup(`<strong>${museum.name}</strong><br>POV: ${museum.pov}<br><span style="color:${markerColor}"><strong>${ownerName}</strong></span>`);
    });
  }
</script>