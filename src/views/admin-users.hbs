{{> menu active="admin"}}

<section class="section">
  <div class="container">
    <h1 class="title">{{title}}</h1>
    <h2 class="subtitle">Manage all users</h2>
    
    <table class="table is-fullwidth is-striped is-hoverable">
      <thead>
        <tr>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each users}}
          <tr>
            <td>{{this.firstName}}</td>
            <td>{{this.lastName}}</td>
            <td>{{this.email}}</td>
            <td>
              {{#if this.role}}
                <span class="tag is-info">{{this.role}}</span>
              {{else}}
                <span class="tag">user</span>
              {{/if}}
            </td>
            <td>
              
              <div class="buttons">
                
                {{#if (eq this.role "admin")}}
                  <a class="button is-warning is-small" href="/admin/toggleadmin/{{this._id}}">
                    <span class="icon">
                      <i class="fas fa-user-minus"></i>
                    </span>
                    <span>Remove Admin</span>
                  </a>
                {{else}}
                  <a class="button is-success is-small" href="/admin/toggleadmin/{{this._id}}">
                    <span class="icon">
                      <i class="fas fa-user-shield"></i>
                    </span>
                    <span>Make Admin</span>
                  </a>
                {{/if}}

                <a class="button is-danger is-small" href="/admin/deleteuser/{{this._id}}">
                  <span class="icon">
                    <i class="fas fa-trash"></i>
                  </span>
                  <span>Delete</span>
                </a>
              </div>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="5" class="has-text-centered">No users found</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>

<section>
  <canvas id="userMuseumsChart" style="max-height: 260px;"></canvas>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const userMuseums = {{{json userMuseums}}};
    const museumsLabels = userMuseums.map(u => u.email);
    const museumsData = userMuseums.map(u => u.count);

    const museumsCtx = document.getElementById("userMuseumsChart");
    if (museumsCtx) {
      new Chart(museumsCtx, {
        type: "bar",
        data: {
          labels: museumsLabels,
          datasets: [{
            label: "Total Museums per User",
            data: museumsData,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            title: { display: true, text: "Top 5 Users by Museum Count" },
          },
        },
      });
    }
  </script>
</section>
</br>

<section>
  <canvas id="userViewsChart" style="max-height: 260px;"></canvas>
  <script>
    const userViews = {{{json userViews}}};
    const viewsLabels = userViews.map(u => u.email);
    const viewsData = userViews.map(u => u.views);

    const viewsCtx = document.getElementById("userViewsChart");
    if (viewsCtx) {
      new Chart(viewsCtx, {
        type: "bar",
        data: {
          labels: viewsLabels,
          datasets: [{
            label: "Total Museum Views",
            data: viewsData,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            title: { display: true, text: "Top 5 Users by Museum Views" },
          },
        },
      });
    }
  </script>
</section>