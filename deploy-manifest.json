{
    "version": 1,
    "framework": { "name": "hapi", "version": "21.x" },
    "routes": [
      {
        "path": "/*",
        "target": { "kind": "Compute", "src": "default" }
      }
    ],
    "computeResources": [
      {
        "name": "default",
        "runtime": "nodejs22.x",
        "entrypoint": "src/server.js"
      }
    ]
  }
  